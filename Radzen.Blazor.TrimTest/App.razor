@using Radzen
@using Radzen.Blazor
@using System.Linq.Dynamic.Core
@using Radzen.Blazor.TrimTest.Models

@*
    Faithful end-to-end trimming repro (TRIMMING_AUDIT.md). Models come from a separate <IsTrimmable>
    assembly and are bound to the real components by STRING Property / ValueProperty / CategoryProperty -
    never via @context.X templates, which would root the getters and mask the bug.

    The #trim-status element is the single signal the Playwright harness reads:
      running       -> drive did not complete (treated as failure on timeout)
      done          -> dynamic-LINQ over the model succeeded (getters preserved)
      error:<msg>   -> reflection over the trimmed model threw (the hazard)

    RED today: no DAM on the component generics, so the model getters are trimmed and the OrderBy/Where
    drive throws -> error:... GREEN once the library annotates the item-typed component generics; rooting
    RadzenDataGrid<Order> then preserves Order's members app-wide and the drive succeeds -> done.
*@

<div id="trim-status">@status</div>

<ErrorBoundary>
    <ChildContent>
        <RadzenDataGrid TItem="Order" Data="@orders" AllowSorting="true" AllowFiltering="true" AllowGrouping="true">
            <Columns>
                <RadzenDataGridColumn TItem="Order" Property="CustomerName" Title="Customer" />
                <RadzenDataGridColumn TItem="Order" Property="Total" Title="Total" />
                <RadzenDataGridColumn TItem="Order" Property="Status" Title="Status" />
                <RadzenDataGridColumn TItem="Order" Property="Priority" Title="Priority" />   @* nullable enum (L5) *@
                <RadzenDataGridColumn TItem="Order" Property="Customer.City" Title="City" />  @* nested path (H14) *@
            </Columns>
        </RadzenDataGrid>

        <RadzenDropDown TValue="int" Data="@people" TextProperty="FullName" ValueProperty="Id"
                        @bind-Value="@selectedId" AllowFiltering="true" />

        <RadzenChart>
            <RadzenColumnSeries TItem="Sale" Data="@sales" CategoryProperty="Region" ValueProperty="Revenue" />
        </RadzenChart>

        <RadzenScheduler TItem="Appt" Data="@appts" StartProperty="Start" EndProperty="End" TextProperty="Text">
            <RadzenMonthView />
        </RadzenScheduler>

        <RadzenUpload Url="upload" Multiple="true" />
    </ChildContent>
    <ErrorContent Context="ex">
        <div>@SetError(ex)</div>
    </ErrorContent>
</ErrorBoundary>

@code {
    string status = "running";
    int selectedId;

    Order[] orders =
    [
        new() { CustomerName = "Alice", Total = 42, Status = OrderStatus.New,        Customer = new() { City = "Sofia" } },
        new() { CustomerName = "Bob",   Total = 87, Status = OrderStatus.Shipped,    Customer = new() { City = "Varna" } },
        new() { CustomerName = "Carol", Total = 15, Status = OrderStatus.Processing, Customer = new() { City = "Sofia" } },
    ];
    Person[] people = [new() { Id = 1, FullName = "Alice" }, new() { Id = 2, FullName = "Bob" }];
    Sale[] sales = [new() { Region = "EU", Revenue = 100 }, new() { Region = "US", Revenue = 200 }];
    Appt[] appts = [new() { Start = new DateTime(2026, 1, 1), End = new DateTime(2026, 1, 2), Text = "Kickoff" }];

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return Task.CompletedTask;

        // Synchronous, catchable dynamic-LINQ over the model - the same engine the grid uses for
        // sort/filter/group. ErrorBoundary does NOT catch OnAfterRenderAsync exceptions, so we catch here.
        try
        {
            _ = orders.AsQueryable().OrderBy("CustomerName").ToList();
            _ = orders.AsQueryable().Where("CustomerName.Contains(@0)", new object[] { "A" }).ToList();
            _ = orders.AsQueryable().GroupByMany(new[] { "Status" }).ToList();
            status = "done";
        }
        catch (Exception ex)
        {
            status = $"error:{ex.GetType().Name}: {ex.Message}";
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    string SetError(Exception ex)
    {
        // Render-time failure sink (e.g. a cell getter throwing).
        status = $"error:{ex.GetType().Name}: {ex.Message}";
        return status;
    }
}
