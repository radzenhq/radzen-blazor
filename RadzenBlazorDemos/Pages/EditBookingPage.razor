@inject DialogService DialogService

<RadzenTemplateForm TItem="RoomBooking" Data="@model" Submit=@OnSubmit>
    <RadzenStack Gap="1rem">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap">
            <RadzenLabel Text="Title" Style="width: 5rem;" />
            <RadzenTextBox @bind-Value="@model.Text" Name="Text" Style="width: 14rem;" />
            <RadzenRequiredValidator Component="Text" Text="Title is required" />
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap">
            <RadzenLabel Text="Rooms" Style="width: 5rem;" />
            <RadzenDropDown @bind-Value="@roomIds" Data="@Rooms" TextProperty="Name" ValueProperty="Id" Multiple="true" Chips="true" Name="Rooms" Style="width: 14rem;" />
            <RadzenRequiredValidator Component="Rooms" Text="Select at least one room" />
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap">
            <RadzenLabel Text="Start" Style="width: 5rem;" />
            <RadzenDatePicker @bind-Value="@model.Start" Name="Start" ShowTime="true" Style="width: 14rem;" />
            <RadzenRequiredValidator Component="Start" Text="Start is required" />
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap">
            <RadzenLabel Text="End" Style="width: 5rem;" />
            <RadzenDatePicker Name="End" @bind-Value="@model.End" ShowTime="true" Style="width: 14rem;" />
            <RadzenRequiredValidator Component="End" Text="End is required" />
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
            <RadzenButton ButtonType="ButtonType.Submit" Text="Save" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter]
    public RoomBooking Booking { get; set; }

    [Parameter]
    public IEnumerable<Room> Rooms { get; set; }

    RoomBooking model = new RoomBooking();
    IEnumerable<int> roomIds = Array.Empty<int>();

    protected override void OnParametersSet()
    {
        model.Text = Booking.Text;
        model.Start = Booking.Start;
        model.End = Booking.End;
        roomIds = Booking.RoomIds.ToArray();
    }

    void OnSubmit(RoomBooking model)
    {
        model.RoomIds = roomIds.ToList();

        DialogService.Close(model);
    }
}
