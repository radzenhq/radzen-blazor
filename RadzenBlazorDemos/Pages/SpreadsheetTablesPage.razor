@page "/spreadsheet-tables"

<RadzenText TextStyle="TextStyle.H2" TagName="TagName.H1" class="rz-pt-8">
    Spreadsheet <strong>Tables</strong>
</RadzenText>
<RadzenText TextStyle="TextStyle.Subtitle1" TagName="TagName.P" class="rz-pb-4">
    Wrap a range in an Excel-style table to get a name, a style, banded rows, a calculated column, and a totals row with SUBTOTAL aggregates. Click any cell inside the table to reveal the Table Design panel, where you can rename the table, switch styles, toggle headers/totals/banded rows, and pick a totals function per column. Right-click a table cell to convert it back to a plain range.
</RadzenText>

<RadzenExample ComponentName="Spreadsheet" Example="SpreadsheetTables">
    <SpreadsheetTables />
</RadzenExample>
