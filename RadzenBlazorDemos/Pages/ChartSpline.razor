<RadzenChart Style="width: 100%; height: 400px;">
    <RadzenLineSeries Data="@data" CategoryProperty="Month" ValueProperty="Temperature" Title="2024" Smooth="true">
        <RadzenMarkers MarkerType="MarkerType.Circle" />
    </RadzenLineSeries>
    <RadzenLineSeries Data="@data2" CategoryProperty="Month" ValueProperty="Temperature" Title="2023" Smooth="true" LineType="LineType.Dashed">
        <RadzenMarkers MarkerType="MarkerType.Square" />
    </RadzenLineSeries>
    <RadzenAreaSeries Data="@data" CategoryProperty="Month" ValueProperty="Rainfall" Title="Rainfall 2024" Smooth="true" />
    <RadzenCategoryAxis />
    <RadzenValueAxis>
        <RadzenGridLines Visible="true" />
    </RadzenValueAxis>
    <RadzenLegend Position="LegendPosition.Bottom" />
</RadzenChart>

