@page "/menu"

<RadzenText TextStyle="TextStyle.H2" TagName="TagName.H1" class="rz-pt-8">
    Blazor Menu
</RadzenText>
<RadzenText TextStyle="TextStyle.Subtitle1" TagName="TagName.P" class="rz-pb-4">
    The Blazor Menu builds horizontal or vertical navigation menus with nested submenus, icons, and templates.
</RadzenText>

<RadzenExample ComponentName="Menu" Example="MenuConfig">
    <MenuConfig />
</RadzenExample>

<RadzenText Anchor="menu#keyboard-navigation" TextStyle="TextStyle.H5" TagName="TagName.H2" class="rz-pt-12">
    Keyboard Navigation
</RadzenText>
<RadzenText TextStyle="TextStyle.Body1" class="rz-mb-8">
    The following keys or key combinations provide a way for users to navigate and interact with Radzen Blazor Menu component.
</RadzenText>

<KeyboardNavigationDataGrid Data="@shortcuts" />

@code {
    public List<KeyboardShortcut> shortcuts = new()
    {
        new KeyboardShortcut { Key = "Tab", Action = "Navigate to a Menu." },
        new KeyboardShortcut { Key = "RightArrow", Action = "Focus next top Menu item." },
        new KeyboardShortcut { Key = "LeftArrow", Action = "Focus previous top Menu item." },
        new KeyboardShortcut { Key = "DownArrow", Action = "On a top-level item with a submenu, open it and focus its first item; within a submenu, focus the next item, wrapping from the last item to the first." },
        new KeyboardShortcut { Key = "UpArrow", Action = "On a top-level item with a submenu, open it and focus its last item; within a submenu, focus the previous item, wrapping from the first item to the last." },
        new KeyboardShortcut { Key = "RightArrow / LeftArrow", Action = "Open / close nested submenus in context and flyout menus." },
        new KeyboardShortcut { Key = "Home", Action = "Focus first item in the current menu." },
        new KeyboardShortcut { Key = "End", Action = "Focus last item in the current menu." },
        new KeyboardShortcut { Key = "Space or Enter on an expandable Menu item", Action = "Expand the Menu item and focus its first item." },
        new KeyboardShortcut { Key = "Esc", Action = "Close the current open submenu and return focus to its parent menu item." },
        new KeyboardShortcut { Key = "Space or Enter on a non-expandable Menu item", Action = "Navigate." },
        new KeyboardShortcut { Key = "A printable character", Action = "Focus the next item whose text starts with that character." }
    };
}
