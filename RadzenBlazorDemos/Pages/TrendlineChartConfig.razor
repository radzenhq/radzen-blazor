<RadzenStack class="rz-p-0 rz-p-md-6 rz-p-lg-12">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" class="rz-mb-4">
        <RadzenCheckBox @bind-Value="showLinear" Name="cbLinear" />
        <RadzenLabel Text="Linear" Component="cbLinear" />
        <RadzenCheckBox @bind-Value="showPolynomial" Name="cbPoly" />
        <RadzenLabel Text="Polynomial (order 3)" Component="cbPoly" />
        <RadzenCheckBox @bind-Value="showMovingAverage" Name="cbMA" />
        <RadzenLabel Text="Moving Average (period 3)" Component="cbMA" />
    </RadzenStack>
    <RadzenRow>
        <RadzenColumn Size="12">
            <RadzenChart>
                <RadzenLineSeries Data="@salesData" CategoryProperty="Month" ValueProperty="Revenue"
                    Title="Monthly Revenue" Stroke="rgba(97,142,247,0.8)" StrokeWidth="2">
                    <RadzenMarkers MarkerType="MarkerType.Circle" />
                    <RadzenSeriesTrendLine Visible="@showLinear" Stroke="#EF5350" StrokeWidth="2" LineType="LineType.Dashed" />
                    <RadzenSeriesPolynomialTrendLine Visible="@showPolynomial" Order="3" Stroke="#26A69A" StrokeWidth="2" LineType="LineType.Dashed" />
                    <RadzenSeriesMovingAverageLine Visible="@showMovingAverage" Period="3" Stroke="#FF9800" StrokeWidth="2" LineType="LineType.Dotted" />
                </RadzenLineSeries>
                <RadzenCategoryAxis />
                <RadzenValueAxis>
                    <RadzenGridLines Visible="true" />
                    <RadzenAxisTitle Text="Revenue ($K)" />
                </RadzenValueAxis>
            </RadzenChart>
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

@code {
    bool showLinear = true;
    bool showPolynomial = true;
    bool showMovingAverage = true;

    class DataItem
    {
        public string Month { get; set; }
        public double Revenue { get; set; }
    }

    DataItem[] salesData = new DataItem[]
    {
        new DataItem { Month = "Jan", Revenue = 42 },
        new DataItem { Month = "Feb", Revenue = 48 },
        new DataItem { Month = "Mar", Revenue = 40 },
        new DataItem { Month = "Apr", Revenue = 55 },
        new DataItem { Month = "May", Revenue = 52 },
        new DataItem { Month = "Jun", Revenue = 61 },
        new DataItem { Month = "Jul", Revenue = 58 },
        new DataItem { Month = "Aug", Revenue = 72 },
        new DataItem { Month = "Sep", Revenue = 65 },
        new DataItem { Month = "Oct", Revenue = 78 },
        new DataItem { Month = "Nov", Revenue = 70 },
        new DataItem { Month = "Dec", Revenue = 85 },
    };
}
