@using System.Collections.Generic

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="2rem" Wrap="FlexWrap.Wrap" class="rz-mb-4">
    <RadzenSwitch @bind-Value=@editMode Name="EditMode" />
    <RadzenLabel Text="Edit mode" Component="EditMode" />

    <RadzenSwitch @bind-Value=@showGrid Name="ShowGrid" />
    <RadzenLabel Text="Show grid" Component="ShowGrid" />
</RadzenStack>

<RadzenWidgetGrid Columns="12" Rows="6" RowHeight="80" Gap="8"
                  EditMode=@editMode ShowGrid=@showGrid Change=@OnChange
                  Style="height: 560px; border: var(--rz-border-normal); border-radius: var(--rz-border-radius);">
    @foreach (var widget in widgets)
    {
        <RadzenWidgetGridItem @key=@widget.Id Title=@widget.Title Icon=@widget.Icon
                              @bind-Col=@widget.Col @bind-Row=@widget.Row
                              @bind-ColSpan=@widget.ColSpan @bind-RowSpan=@widget.RowSpan>
            <RadzenText TextStyle="TextStyle.DisplayH4" class="rz-m-0">@widget.Value</RadzenText>
            <RadzenText TextStyle="TextStyle.Caption">@widget.Col,@widget.Row · @widget.ColSpan×@widget.RowSpan</RadzenText>
        </RadzenWidgetGridItem>
    }
    <RadzenWidgetGridItem @bind-Col=@custom.Col @bind-Row=@custom.Row @bind-ColSpan=@custom.ColSpan @bind-RowSpan=@custom.RowSpan>
        <HeaderTemplate>
            <RadzenIcon Icon="insights" Style="color: var(--rz-primary);" />
            <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.Span" class="rz-flex-grow-1 rz-m-0">Custom header</RadzenText>
            <RadzenBadge BadgeStyle="BadgeStyle.Primary" Text="Live" />
        </HeaderTemplate>
        <ChildContent>
            <RadzenText>This widget uses a custom <code>HeaderTemplate</code> and spans multiple cells.</RadzenText>
        </ChildContent>
    </RadzenWidgetGridItem>
</RadzenWidgetGrid>

<EventConsole @ref=@console />

@code {
    bool editMode = true;
    bool showGrid = true;

    EventConsole console;

    class Widget
    {
        public int Id { get; set; }
        public string Title { get; set; }
        public string Icon { get; set; }
        public string Value { get; set; }
        public int Col { get; set; }
        public int Row { get; set; }
        public int ColSpan { get; set; } = 1;
        public int RowSpan { get; set; } = 1;
    }

    Widget custom = new() { Col = 1, Row = 5, ColSpan = 6, RowSpan = 2 };

    List<Widget> widgets = new()
    {
        new Widget { Id = 1, Title = "Revenue", Icon = "paid", Value = "$24.5k", Col = 1, Row = 1, ColSpan = 4, RowSpan = 2 },
        new Widget { Id = 2, Title = "Orders", Icon = "shopping_cart", Value = "1,284", Col = 5, Row = 1, ColSpan = 4, RowSpan = 2 },
        new Widget { Id = 3, Title = "Visitors", Icon = "group", Value = "8,932", Col = 9, Row = 1, ColSpan = 4, RowSpan = 2 },
        new Widget { Id = 4, Title = "Conversion", Icon = "trending_up", Value = "3.2%", Col = 7, Row = 3, ColSpan = 6, RowSpan = 2 },
    };

    void OnChange(RadzenWidgetGridItem item)
    {
        console.Log($"Widget '{item.Title ?? "Custom"}' changed → Col {item.Col}, Row {item.Row}, ColSpan {item.ColSpan}, RowSpan {item.RowSpan}");
    }
}
