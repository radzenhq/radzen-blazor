@page "/tree"
<RadzenText TextStyle="TextStyle.H2" TagName="TagName.H1" class="rz-pt-8">
    Blazor Tree
</RadzenText>
<RadzenText TextStyle="TextStyle.Subtitle1" TagName="TagName.P" class="rz-pb-4">
    Inline definition, data-binding, and keyboard navigation.
</RadzenText>

<RadzenExample ComponentName="Tree" Example="TreeConfig">
    <TreeConfig />
</RadzenExample>

<RadzenText Anchor="tree#keyboard-navigation" TextStyle="TextStyle.H5" TagName="TagName.H2" class="rz-pt-12">
    Keyboard Navigation
</RadzenText>
<RadzenText TextStyle="TextStyle.Body1" class="rz-mb-8">
    The following keys or key combinations provide a way for users to navigate and interact with Radzen Blazor Tree component.
</RadzenText>

<KeyboardNavigationDataGrid Data="@shortcuts" />

@code {
    public List<KeyboardShortcut> shortcuts = new()
    {
        new KeyboardShortcut { Key = "Tab", Action = "Move focus into the Tree." },
        new KeyboardShortcut { Key = "UpArrow", Action = "Move focus to the previous item." },
        new KeyboardShortcut { Key = "DownArrow", Action = "Move focus to the next item." },
        new KeyboardShortcut { Key = "RightArrow", Action = "Expand the focused collapsed item; if already expanded, move focus to its first child; no effect on leaf items." },
        new KeyboardShortcut { Key = "LeftArrow", Action = "Collapse the focused item, or move to its parent if collapsed or a leaf." },
        new KeyboardShortcut { Key = "Home", Action = "Move focus to the first item." },
        new KeyboardShortcut { Key = "End", Action = "Move focus to the last item." },
        new KeyboardShortcut { Key = "Enter", Action = "Select the focused item; on an expandable item also expand or collapse it." },
        new KeyboardShortcut { Key = "Space", Action = "Select the focused item; when checkboxes are enabled, also toggle its checkbox." },
        new KeyboardShortcut { Key = "Alphanumeric", Action = "Move focus to the next item whose text starts with the typed character." }
    };
}