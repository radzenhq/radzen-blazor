@page "/donut-chart"

<RadzenText TextStyle="TextStyle.H2" TagName="TagName.H1" class="rz-pt-8">
    Radzen Blazor Chart donut series
</RadzenText>
<RadzenText TextStyle="TextStyle.Subtitle1" TagName="TagName.P" class="rz-pb-4">
    A donut chart is a pie chart with the center removed, freeing the middle for a total or label. The slices still show each category's share of the whole.
</RadzenText>

<RadzenText Anchor="donut-chart#customization" TextStyle="TextStyle.H5" TagName="TagName.H2" class="rz-pt-8">
    Customization
</RadzenText>
<RadzenExample ComponentName="Chart" Example="DonutChartConfig" DocumentationLink="https://blazor.radzen.com/docs/guides/components/chart.html">
    <DonutChartConfig />
</RadzenExample>

<RadzenText Anchor="donut-chart#various-radius" TextStyle="TextStyle.H5" TagName="TagName.H2" class="rz-pt-12">
    Donut with various radius
</RadzenText>
<RadzenText TextStyle="TextStyle.Body1" TagName="TagName.P" class="rz-pb-4">
    Use the <code>RadiusProperty</code> to assign different outer radius values to each segment based on a data property. The inner radius stays constant while each segment extends outward proportionally.
</RadzenText>

<RadzenExample ComponentName="Chart" Example="DonutChartVariousRadius">
    <DonutChartVariousRadius />
</RadzenExample>

<RadzenText Anchor="donut-chart#explode-on-hover" TextStyle="TextStyle.H5" TagName="TagName.H2" class="rz-pt-12">
    Explode on hover
</RadzenText>
<RadzenText TextStyle="TextStyle.Body1" TagName="TagName.P" class="rz-pb-4">
    Set <code>ExplodeOffset</code> to make segments move outward from the center when hovered.
</RadzenText>

<RadzenExample ComponentName="Chart" Example="DonutChartExplode">
    <DonutChartExplode />
</RadzenExample>

<RadzenText Anchor="donut-chart#segment-gap" TextStyle="TextStyle.H5" TagName="TagName.H2" class="rz-pt-12">
    Segment gap with rounded corners
</RadzenText>
<RadzenText TextStyle="TextStyle.Body1" TagName="TagName.P" class="rz-pb-4">
    Set <code>SegmentGap</code> to separate adjacent segments by a uniform-width space that runs from the outer rim to the inner hole, regardless of segment size, and combines with <code>CornerRadius</code> for rounded edges.
</RadzenText>

<RadzenExample ComponentName="Chart" Example="DonutChartSegmentGap">
    <DonutChartSegmentGap />
</RadzenExample>