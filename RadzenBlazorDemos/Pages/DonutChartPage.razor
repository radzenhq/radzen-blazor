@page "/donut-chart"

<RadzenText TextStyle="TextStyle.H2" TagName="TagName.H1" class="rz-pt-8">
    Radzen Blazor Chart donut series
</RadzenText>
<RadzenText TextStyle="TextStyle.Subtitle1" TagName="TagName.P" class="rz-pb-4">
    Display proportional data with a center hollow using donut charts.
</RadzenText>

<RadzenExample ComponentName="Chart" Example="DonutChartConfig" DocumentationLink="https://blazor.radzen.com/docs/guides/components/chart.html">
    <DonutChartConfig />
</RadzenExample>

<RadzenText TextStyle="TextStyle.H5" TagName="TagName.H2" class="rz-pt-12">
    Donut with various radius
</RadzenText>
<RadzenText TextStyle="TextStyle.Body1" TagName="TagName.P" class="rz-pb-4">
    Use the <code>RadiusProperty</code> to assign different outer radius values to each segment based on a data property. The inner radius stays constant while each segment extends outward proportionally.
</RadzenText>

<RadzenExample ComponentName="Chart" Example="DonutChartVariousRadius">
    <DonutChartVariousRadius />
</RadzenExample>

<RadzenText TextStyle="TextStyle.H5" TagName="TagName.H2" class="rz-pt-12">
    Explode on hover
</RadzenText>
<RadzenText TextStyle="TextStyle.Body1" TagName="TagName.P" class="rz-pb-4">
    Set <code>ExplodeOffset</code> to make segments move outward from the center when hovered.
</RadzenText>

<RadzenExample ComponentName="Chart" Example="DonutChartExplode">
    <DonutChartExplode />
</RadzenExample>