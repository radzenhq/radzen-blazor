@inject DialogService DialogService

<RadzenScheduler @ref=@scheduler style="height: 768px;" TItem="RoomBooking" Data=@bookings StartProperty="Start" EndProperty="End" TextProperty="Text"
    Resources=@rooms ResourceTextProperty="Name" ResourceValueProperty="Id" ResourceProperty="RoomIds"
    SlotSelect=@OnSlotSelect AppointmentSelect=@OnAppointmentSelect AppointmentMove=@OnAppointmentMove>
    <RadzenDayView GroupByResource="true" />
    <RadzenWeekView GroupByResource="true" />
    <RadzenMonthView GroupByResource="true" />
    <RadzenWeekView Text="Plain Week" />
</RadzenScheduler>

<EventConsole @ref=@console />

@code {
    RadzenScheduler<RoomBooking> scheduler;
    EventConsole console;

    IList<Room> rooms = new List<Room>
    {
        new Room { Id = 1, Name = "Meeting Room" },
        new Room { Id = 2, Name = "Conference Hall" },
        new Room { Id = 3, Name = "Projector" },
        new Room { Id = 4, Name = "Company Car" }
    };

    IList<RoomBooking> bookings = new List<RoomBooking>
    {
        new RoomBooking { RoomIds = new List<int> { 1 }, Start = DateTime.Today.AddHours(9), End = DateTime.Today.AddHours(10), Text = "Daily stand-up" },
        new RoomBooking { RoomIds = new List<int> { 1 }, Start = DateTime.Today.AddHours(13), End = DateTime.Today.AddHours(15), Text = "Sprint planning" },
        new RoomBooking { RoomIds = new List<int> { 2, 3 }, Start = DateTime.Today.AddHours(10), End = DateTime.Today.AddHours(12), Text = "Customer demo" },
        new RoomBooking { RoomIds = new List<int> { 2 }, Start = DateTime.Today.AddDays(1).AddHours(11), End = DateTime.Today.AddDays(1).AddHours(12), Text = "Interview" },
        new RoomBooking { RoomIds = new List<int> { 4 }, Start = DateTime.Today, End = DateTime.Today.AddDays(1), Text = "Off-site visit" },
    };

    async Task OnSlotSelect(SchedulerSlotSelectEventArgs args)
    {
        var room = args.Resource as Room;

        console.Log($"SlotSelect: Start={args.Start} End={args.End} Room={room?.Name ?? "(none)"}");

        var booking = new RoomBooking { Start = args.Start, End = args.End };

        if (room != null)
        {
            booking.RoomIds.Add(room.Id);
        }

        var result = await DialogService.OpenAsync<EditBookingPage>("Add Booking",
            new Dictionary<string, object> { { "Booking", booking }, { "Rooms", rooms } });

        if (result != null)
        {
            bookings.Add(result);

            await scheduler.Reload();
        }
    }

    async Task OnAppointmentSelect(SchedulerAppointmentSelectEventArgs<RoomBooking> args)
    {
        console.Log($"AppointmentSelect: Text={args.Data.Text} Rooms={string.Join(", ", rooms.Where(r => args.Data.RoomIds.Contains(r.Id)).Select(r => r.Name))}");

        var result = await DialogService.OpenAsync<EditBookingPage>("Edit Booking",
            new Dictionary<string, object> { { "Booking", args.Data }, { "Rooms", rooms } });

        if (result != null)
        {
            args.Data.Text = result.Text;
            args.Data.Start = result.Start;
            args.Data.End = result.End;
            args.Data.RoomIds = result.RoomIds;

            await scheduler.Reload();
        }
    }

    async Task OnAppointmentMove(SchedulerAppointmentMoveEventArgs args)
    {
        var booking = bookings.FirstOrDefault(b => b == args.Appointment.Data);

        if (booking != null)
        {
            booking.Start = booking.Start + args.TimeSpan;
            booking.End = booking.End + args.TimeSpan;

            if (args.Resource is Room room && !booking.RoomIds.Contains(room.Id))
            {
                booking.RoomIds = new List<int> { room.Id };
            }

            await scheduler.Reload();
        }
    }
}
