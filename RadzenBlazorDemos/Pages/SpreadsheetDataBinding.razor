@using RadzenBlazorDemos.Data
@using RadzenBlazorDemos.Models.Northwind
@using Microsoft.EntityFrameworkCore
@using Radzen.Blazor.Spreadsheet
@using Radzen.Documents.Spreadsheet

@inherits DbContextPage

<RadzenSpreadsheet Workbook=@workbook style="height: 600px" />

@code {
    Workbook workbook;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        var employees = dbContext.Employees.AsQueryable();

        var columnMappings = new IColumnMapping<Employee>[]
        {
            ColumnMapping.Create("ID", (Employee e) => e.EmployeeID),
            ColumnMapping.Create("First Name", (Employee e) => e.FirstName),
            ColumnMapping.Create("Last Name", (Employee e) => e.LastName),
            ColumnMapping.Create("Title", (Employee e) => e.Title),
            ColumnMapping.Create("City", (Employee e) => e.City),
            ColumnMapping.Create("Country", (Employee e) => e.Country),
        };

        var dataSheet = new DataSheet<Employee>(employees, columnMappings);
        dataSheet.Name = "Employees";

        workbook = new Workbook();
        workbook.AddSheet(dataSheet);
    }
}