<RadzenStack class="rz-p-0 rz-p-md-6 rz-p-lg-12">
    <RadzenRow>
        <RadzenColumn Size="12">
            <RadzenChart Style="height: 600px">
                <RadzenStackedBarSeries Data="@female" CategoryProperty="AgeGroup" ValueProperty="Percentage" Title="Female" />
                <RadzenStackedBarSeries Data="@male" CategoryProperty="AgeGroup" ValueProperty="Percentage" Title="Male" />
                <RadzenBarOptions Radius="0" />
                <RadzenValueAxis Formatter="@FormatPercentage" Min="-6" Max="6" Step="3">
                    <RadzenGridLines Visible="true" />
                    <RadzenAxisTitle Text="Share of Total Population (%)" />
                </RadzenValueAxis>
                <RadzenCategoryAxis>
                    <RadzenAxisTitle Text="Population by Age Range" />
                </RadzenCategoryAxis>
                <RadzenLegend Position="LegendPosition.Bottom" />
            </RadzenChart>
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

@code {
    string FormatPercentage(object value)
    {
        return $"{Math.Abs((double)value)}%";
    }

    class PopulationData
