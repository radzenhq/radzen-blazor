@page "/splitter"

<RadzenText TextStyle="TextStyle.H2" TagName="TagName.H1" class="rz-pt-8">
    Blazor Splitter
</RadzenText>
<RadzenText TextStyle="TextStyle.Subtitle1" TagName="TagName.P" class="rz-pb-4">
    The Blazor Splitter divides an area into resizable, collapsible panes, horizontally or vertically.
</RadzenText>

<RadzenExample ComponentName="Splitter" Example="SplitterConfig">
    <SplitterConfig />
</RadzenExample>

<RadzenText Anchor="splitter#keyboard-navigation" TextStyle="TextStyle.H5" TagName="TagName.H2" class="rz-pt-12">
    Keyboard Navigation
</RadzenText>
<RadzenText TextStyle="TextStyle.Body1" class="rz-mb-8">
    The following keys resize the panes when a resize bar is focused.
</RadzenText>

<KeyboardNavigationDataGrid Data="@shortcuts" />

@code {
    public List<KeyboardShortcut> shortcuts = new()
    {
        new KeyboardShortcut { Key = "Tab", Action = "Move focus to the next resize bar or collapse/expand button." },
        new KeyboardShortcut { Key = "Left or Right Arrow", Action = "Resize the panes of a horizontal Splitter." },
        new KeyboardShortcut { Key = "Up or Down Arrow", Action = "Resize the panes of a vertical Splitter." },
        new KeyboardShortcut { Key = "Home", Action = "Resize the pane to its minimum (smallest allowed) size." },
        new KeyboardShortcut { Key = "End", Action = "Resize the pane to its maximum (largest allowed) size." },
        new KeyboardShortcut { Key = "Enter or Space", Action = "Collapse or restore the focused pane (on the resize bar or the collapse/expand button)." }
    };
}
