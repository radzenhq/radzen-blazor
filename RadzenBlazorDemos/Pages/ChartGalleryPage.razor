@page "/chart-gallery"

<PageTitle>Blazor Chart Components Gallery — 50+ Free Chart Types | Radzen</PageTitle>
<HeadContent>
    <meta name="description" content="Browse 50+ free Blazor chart types — area, bar, column, line, pie, donut, scatter, financial, gauge and more. View live demos with configuration options.">
</HeadContent>

<RadzenText TextStyle="TextStyle.H2" TagName="TagName.H1" class="rz-pt-8">
    Blazor Chart Components Gallery
</RadzenText>
<RadzenText TextStyle="TextStyle.Subtitle1" TagName="TagName.P" class="rz-pb-4" Style="max-width: 1200px;">
    Explore free, open-source Blazor chart components — from area, bar, and line charts to financial, statistical, and gauge visualizations. Each supports data binding, tooltips, legends, and theming. Click any chart to view its live demo.
</RadzenText>

<style>
    .chart-gallery .rz-link {
        --rz-link-text-decoration: none;
        --rz-link-hover-text-decoration: none;
        color: inherit;
        display: block;
        transition: transform 0.15s;
        
        .rz-card {
            transition: box-shadow 0.2s;
        }
    }

    .chart-gallery .rz-link:hover {
        transform: translateY(-2px);
        
        .rz-card {
            box-shadow: var(--rz-shadow-2);
        }
    }

    .chart-gallery .rz-card {
        height: 100%;
    }

    .chart-gallery-thumb {
        width: 100%;
        height: 150px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .chart-gallery-thumb svg {
        width: 100%;
        height: 100%;
    }
</style>

