@page "/spreadsheet"

<RadzenText TextStyle="TextStyle.H2" TagName="TagName.H1" class="rz-pt-8">
    Spreadsheet
</RadzenText>
<RadzenText TextStyle="TextStyle.Subtitle1" TagName="TagName.P" class="rz-pb-4">
    Free open-source Blazor Spreadsheet component with Excel-like editing, formulas, cell formatting, filtering, sorting, data validation, conditional formatting, frozen panes, XLSX import/export, clipboard, autofill, undo/redo, multiple sheets, virtualization, custom cell types, and data binding.
</RadzenText>

<RadzenExample ComponentName="Spreadsheet" Example="SpreadsheetConfig">
    <SpreadsheetConfig />
</RadzenExample>

<RadzenText Anchor="spreadsheet#keyboard-navigation" TextStyle="TextStyle.H5" TagName="TagName.H2" class="rz-pt-12">
    Keyboard Navigation
</RadzenText>
<RadzenText TextStyle="TextStyle.Body1" class="rz-mb-4">
    These are the most common keys for navigating and editing the spreadsheet. Press
    <span class="rz-badge rz-badge-primary rz-variant-filled rz-shade-default">Alt+/</span>
    in the spreadsheet to see all supported keyboard shortcuts.
</RadzenText>

<KeyboardNavigationDataGrid Data="@data" />

@code {
    List<KeyboardShortcut> data = new List<KeyboardShortcut>
    {
        new KeyboardShortcut { Key = "Arrow keys", Action = "Move between cells." },
        new KeyboardShortcut { Key = "Tab", Action = "Move to the next cell." },
        new KeyboardShortcut { Key = "Enter", Action = "Confirm edit and move to the cell below." },
        new KeyboardShortcut { Key = "F6", Action = "Move between the toolbar, grid and sheet tabs (Shift + F6 to go back)." },
        new KeyboardShortcut { Key = "Ctrl + Z", Action = "Undo the last action." },
        new KeyboardShortcut { Key = "Alt + /", Action = "Show all keyboard shortcuts." },
    };
}
