<RadzenChart Style="width: 100%; height: 400px;">
    <RadzenFunnelSeries Data="@stages" CategoryProperty="Stage" ValueProperty="Count"
                        Fills="@(new[] { "var(--rz-series-1)", "var(--rz-series-2)", "var(--rz-series-3)", "var(--rz-series-4)", "var(--rz-series-5)" })"
                        StrokeWidth="1" Strokes="@(new[] { "white", "white", "white", "white", "white" })">
        <RadzenSeriesDataLabels Visible="true" />
    </RadzenFunnelSeries>
    <RadzenLegend Position="LegendPosition.Bottom" />
</RadzenChart>

@code {
    class FunnelData
    {
        public string Stage { get; set; }
        public double Count { get; set; }
    }

    FunnelData[] stages = new[]
    {
        new FunnelData { Stage = "Visitors", Count = 5000 },
        new FunnelData { Stage = "Leads", Count = 3200 },
        new FunnelData { Stage = "Prospects", Count = 1800 },
        new FunnelData { Stage = "Negotiations", Count = 900 },
        new FunnelData { Stage = "Closed Deals", Count = 450 },
    };
}
