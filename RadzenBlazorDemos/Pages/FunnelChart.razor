<RadzenStack class="rz-p-0 rz-p-md-6 rz-p-lg-12">
    <RadzenCard Variant="Variant.Outlined">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenCheckBox @bind-Value="inverted" Name="inverted" />
                <RadzenLabel Text="Inverted" Component="inverted" />
            </RadzenStack>
        </RadzenStack>
    </RadzenCard>

    <RadzenChart Style="width: 100%; height: 400px;">
    <RadzenFunnelSeries Data="@stages" CategoryProperty="Stage" ValueProperty="Count" Inverted="@inverted"
                        StrokeWidth="1" Strokes="@(new[] { "var(--rz-base-background-color)", "var(--rz-base-background-color)", "var(--rz-base-background-color)", "var(--rz-base-background-color)", "var(--rz-base-background-color)" })">
        <RadzenSeriesDataLabels Visible="true" />
    </RadzenFunnelSeries>
    <RadzenLegend Position="LegendPosition.Right" />
    </RadzenChart>
</RadzenStack>

@code {
    bool inverted;

    class FunnelData
    {
        public string Stage { get; set; }
        public double Count { get; set; }
    }

    FunnelData[] stages = new[]
    {
        new FunnelData { Stage = "Visitors", Count = 5000 },
        new FunnelData { Stage = "Leads", Count = 3200 },
        new FunnelData { Stage = "Prospects", Count = 1800 },
        new FunnelData { Stage = "Negotiations", Count = 900 },
        new FunnelData { Stage = "Closed Deals", Count = 450 },
    };
}
