@inject ExampleService ExampleService
@inject NavigationManager NavigationManager
@implements IDisposable

<div style="padding: 1rem">
    <RadzenTextBox id="find" Placeholder="Find component ..." type="search" @oninput="@FilterPanelMenu" style="width: 100%" class="rz-search-input" aria-label="find" />
</div>
<div style="flex: 1; overflow: auto">
    <RadzenPanelMenu Match="NavLinkMatch.Prefix" RenderMode="PanelMenuRenderMode.Server">
        @foreach (var category in examples)
        {
            @if (category.Children != null)
            {
            <NavigationItem @key=category Example=@category>
            @foreach (var example in category.Children)
            {
                if (example.Children != null)
                {
                    <NavigationItem @key=example Example=@example>
                    @foreach (var child in example.Children)
                    {
                        <NavigationItem @key=child Example=@child />
                    }
                    </NavigationItem>
                }
                else
                {
                    <NavigationItem @key=example Example=@example />
                }
            }
            </NavigationItem>
            }
            else
            {
                <NavigationItem @key=category Example=@category />
            }
        }
    </RadzenPanelMenu>
</div>
@code {
    IEnumerable<Example> examples;

    protected override void OnInitialized()
    {
        examples = ExampleService.Examples;
        ExpandCurrent();
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    void OnLocationChanged(object sender, LocationChangedEventArgs args)
    {
        ExpandCurrent();
        InvokeAsync(StateHasChanged);
    }

    void ExpandCurrent()
    {
        var path = new Uri(NavigationManager.Uri).AbsolutePath.Trim('/');
        ExpandPathTo(ExampleService.Examples, path);
    }

    bool ExpandPathTo(IEnumerable<Example> items, string path)
    {
        if (items == null)
        {
            return false;
        }

        var found = false;

        foreach (var item in items)
        {
            var isMatch = !string.IsNullOrEmpty(item.Path) && item.Path.Trim('/') == path;
            var childMatch = ExpandPathTo(item.Children, path);

            if (childMatch)
            {
                item.Expanded = true;
            }

            found = found || isMatch || childMatch;
        }

        return found;
    }

    void FilterPanelMenu(ChangeEventArgs args)
    {
        var term = args.Value.ToString();

        examples = string.IsNullOrEmpty(term) ? ExampleService.Examples : ExampleService.Filter(term);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}