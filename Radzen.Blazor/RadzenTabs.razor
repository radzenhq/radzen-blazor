@inherits RadzenComponent
@using System.Linq
@using Microsoft.JSInterop
<CascadingValue Value=this>
@if (Visible)
{
    <div @ref=@Element style=@Style @attributes=@Attributes class=@GetCssClass() id=@GetId()>
        <ul @ref=@tablistElement class="rz-tabview-nav"
            role="tablist"
            aria-orientation="@(IsVertical ? "vertical" : "horizontal")"
            aria-label="@AriaLabel"
            aria-labelledby="@AriaLabelledBy"
            aria-activedescendant="@GetActiveDescendantId()"
            tabindex=0 @onkeydown="@(args => OnKeyPress(args))" @onkeydown:preventDefault=preventKeyPress @onkeydown:stopPropagation="stopKeydownPropagation">
            @Tabs
        </ul>
        <div class="rz-tabview-panels">
            @if(RenderMode == TabRenderMode.Client)
            {
                for (var i = 0; i < tabs.Count; i++)
                {
                <div @onkeydown:stopPropagation class="rz-tabview-panel" role="tabpanel" id="@($"{Id}-tabpanel-{i}")" style="@(tabs[i] == SelectedTab ? "" : "display:none")" aria-hidden="@(tabs[i] == SelectedTab ? "false" : "true")" aria-labelledby="@($"{Id}-tabpanel-{i}-label")">
                    @tabs[i].ChildContent
                </div>                            
                }
            }
            else
            {
                for (var i = 0; i < tabs.Count; i++)
                {
                    @if (tabs[i] == SelectedTab && SelectedTab?.Visible == true)
                    {
                        <div @onkeydown:stopPropagation class="rz-tabview-panel" role="tabpanel" id="@($"{Id}-tabpanel-{i}")" aria-hidden="false" aria-labelledby="@($"{Id}-tabpanel-{i}-label")">
                            @SelectedTab.ChildContent
                        </div>
                    }
                    else if (tabs[i].Visible)
                    {
                        <div class="rz-tabview-panel" role="tabpanel" id="@($"{Id}-tabpanel-{i}")" tabindex="-1" style="display:none" aria-hidden="true" aria-labelledby="@($"{Id}-tabpanel-{i}-label")"></div>
                    }
                }
            }
        </div>
    </div>
}
</CascadingValue>
