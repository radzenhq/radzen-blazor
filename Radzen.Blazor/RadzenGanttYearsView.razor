@using System.Globalization
@using Radzen.Blazor.Rendering
@typeparam TItem where TItem : notnull
@inherits SchedulerViewBase

@code {
    [CascadingParameter]
    internal RadzenGantt<TItem>? Gantt { get; set; }

    public override string Icon => "date_range";

    private string? text;

    [Parameter]
    public override string Text { get => text ?? Localize(nameof(RadzenStrings.Gantt_YearsViewText)); set => text = value; }

    public override string Title
    {
        get
        {
            var culture = Scheduler?.Culture ?? CultureInfo.CurrentCulture;
            var end = EndDate.AddDays(-1);
            if (StartDate.Year == end.Year)
            {
                return StartDate.ToString("yyyy", culture);
            }
            return $"{StartDate.ToString("yyyy", culture)} - {end.ToString("yyyy", culture)}";
        }
    }

    public override DateTime StartDate
    {
        get
        {
            if (Gantt?.ViewStart.HasValue == true)
            {
                var start = Gantt.ViewStart.Value.Date;
                return QuarterStart(start);
            }

            var date = Scheduler?.CurrentDate.Date ?? DateTime.Today;
            return new DateTime(date.Year, 1, 1);
        }
    }

    public override DateTime EndDate
    {
        get
        {
            if (Gantt?.ViewEnd.HasValue == true)
            {
                var end = Gantt.ViewEnd.Value.Date;
                return QuarterStart(end).AddMonths(3);
            }

            var years = Math.Max(1, Gantt?.YearsInView ?? 3);
            return StartDate.AddYears(years);
        }
    }

    public override DateTime Next()
    {
        var years = Math.Max(1, Gantt?.YearsInView ?? 3);
        return (Scheduler?.CurrentDate.Date ?? DateTime.Today).AddYears(years);
    }

    public override DateTime Prev()
    {
        var years = Math.Max(1, Gantt?.YearsInView ?? 3);
        return (Scheduler?.CurrentDate.Date ?? DateTime.Today).AddYears(-years);
    }

    public override RenderFragment Render()
    {
        var appointments = Scheduler?.GetAppointmentsInRange(StartDate, EndDate).ToList() ?? new List<AppointmentData>();
        var culture = Scheduler?.Culture ?? CultureInfo.CurrentCulture;
        var quarterFormat = Localize(nameof(RadzenStrings.Gantt_QuarterFormat));
        var columns = BuildQuarterColumns(StartDate, EndDate, Gantt?.DayWidthPx ?? 80, culture, quarterFormat);
        var timelineWidth = columns.Sum(c => c.WidthPx);

        Gantt?.ComputeCriticalPath(appointments, Gantt?.TimelineRowIndexByItem);

        return @<CascadingValue Value=@Scheduler>
            <GanttTimelineView TItem="TItem" StartDate=@StartDate
                               EndDate=@EndDate
                               Columns=@columns
                               TimelineWidthPx=@timelineWidth
                               RowCount=@(Gantt?.TimelineRowCount ?? 0)
                               RowIndexByItem=@(Gantt?.TimelineRowIndexByItem)
                               RowHeightPx=@(Gantt?.RowHeightPx ?? 36)
                               Appointments=@appointments
                               Dependencies=@(Gantt?.TimelineDependencies)
                               CriticalItems=@(Gantt?.CriticalPathItems)
                               BaselineStartProperty=@(Gantt?.TimelineBaselineStartProperty)
                               BaselineEndProperty=@(Gantt?.TimelineBaselineEndProperty)
                               ShowTodayLine=@(Gantt?.TimelineShowTodayLine ?? true)
                               ShowWeekends="false"
                               NonWorkingDays=@(Gantt?.TimelineNonWorkingDays)
                               Markers=@(Gantt?.TimelineMarkers)
                               TaskRender=@(Gantt?.TimelineTaskRender)
                               LaneByItem=@(Gantt?.LaneByItem)
                               LaneCountByRow=@(Gantt?.LaneCountByRow)
                               AppointmentMove=OnAppointmentMove />
        </CascadingValue>;
    }

    internal const double AverageDaysPerQuarter = 91.3106;

    internal static IReadOnlyList<GanttTimelineView<TItem>.GanttTimelineColumn> BuildQuarterColumns(DateTime start, DateTime end, int quarterWidth, CultureInfo culture, string quarterFormat)
    {
        var columns = new List<GanttTimelineView<TItem>.GanttTimelineColumn>();
        var current = QuarterStart(start);
        while (current < end.Date)
        {
            var next = current.AddMonths(3);
            var daysInQuarter = (next - current).TotalDays;
            var quarter = (current.Month - 1) / 3 + 1;
            columns.Add(new GanttTimelineView<TItem>.GanttTimelineColumn
            {
                Start = current,
                End = next,
                Label = string.Format(culture, quarterFormat, quarter),
                GroupLabel = current.ToString("yyyy", culture),
                WidthPx = quarterWidth * daysInQuarter / AverageDaysPerQuarter
            });
            current = next;
        }
        return columns;
    }

    private static DateTime QuarterStart(DateTime date)
    {
        var quarterMonth = ((date.Month - 1) / 3) * 3 + 1;
        return new DateTime(date.Year, quarterMonth, 1);
    }
}
