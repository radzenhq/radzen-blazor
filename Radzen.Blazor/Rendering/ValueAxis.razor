
@inherits RadzenChartComponentBase
@if (YAxis?.Visible == true)
{
    <g class="rz-axis rz-value-axis @(IsRightSide ? "rz-value-axis-right" : "")">
    <Line class="rz-line" X1="@axisX" Y1="@y1" X2="@axisX" Y2="@y2" Stroke="@YAxis.Stroke" StrokeWidth="@YAxis.StrokeWidth" LineType="@YAxis.LineType" />
    @for (var idx = start; idx <= end; idx += step)
    {
        var value = scale?.Value(idx);
        var y = scale?.Scale(idx) ?? 0;
        var text = value != null && YAxis != null && scale != null ? YAxis.Format(scale, value) : "";

        if (YAxis?.Ticks?.Template != null)
        {
            var context = new TickTemplateContext { Text = text, Value = value, X = axisX, Y = y } ;

            <ValueAxisTick X="@axisX" Y="@y" Text="@text" Stroke="@(YAxis.Ticks.Stroke ?? YAxis.Stroke)" StrokeWidth="@YAxis.Ticks.StrokeWidth" LineType="@YAxis.Ticks.LineType" RightSide="@IsRightSide">
                @YAxis.Ticks.Template(context)
            </ValueAxisTick>
        }
        else if (!String.IsNullOrEmpty(text))
        {
            <ValueAxisTick X="@axisX" Y="@y" Text="@text" Stroke="@(YAxis?.Ticks?.Stroke ?? YAxis?.Stroke)" StrokeWidth="@(YAxis?.Ticks?.StrokeWidth ?? 0)" LineType="@(YAxis?.Ticks?.LineType ?? LineType.Solid)" RightSide="@IsRightSide" />
        }

        if (YAxis?.GridLines?.Visible == true && idx > start)
        {
            <Line class="rz-grid-line" X1="@x1" Y1="@y" X2="@x2" Y2="@y" Stroke="@(YAxis.GridLines.Stroke)" StrokeWidth="@(YAxis.GridLines.StrokeWidth)" LineType="@(YAxis.GridLines.LineType)" />
        }
    }
    @if (!String.IsNullOrEmpty(YAxis?.Title?.Text))
    {
        if (IsRightSide)
        {
            <ValueAxisTitle X="@(axisX + (YAxis?.Size ?? 0) - (YAxis?.Title?.Size ?? 0))" Y="@((y1 - y2)/2)" Text="@(YAxis?.Title?.Text ?? "")" RightSide="true" />
        }
        else
        {
            <ValueAxisTitle X="@(axisX - (Chart?.ValueAxis?.Size ?? 0) + (YAxis?.Title?.Size ?? 0))" Y="@((y1 - y2)/2)" Text="@(YAxis?.Title?.Text ?? "")" />
        }
    }
    </g>
}
@code {
    [Parameter]
    public string? AxisName { get; set; }

    bool IsRightSide => !string.IsNullOrEmpty(AxisName);

    double start;
    double end;
    double step;
    double x1;
    double x2;
    double y1;
    double y2;
    double axisX;
    ScaleBase? scale;
    private AxisBase? XAxis { get; set; }
    private AxisBase? YAxis { get; set; }

    protected override void OnParametersSet()
    {
        if (Chart == null)
        {
            return;
        }

        if (IsRightSide)
        {
            YAxis = Chart.GetValueAxis(AxisName);
            scale = Chart.GetValueScale(AxisName);
        }
        else
        {
            YAxis = Chart.ValueAxis;
            scale = Chart.ValueScale;

            if (Chart.ShouldInvertAxes())
            {
                YAxis = Chart.CategoryAxis;
                XAxis = Chart.ValueAxis;
            }
            else
            {
                XAxis = Chart.CategoryAxis;
            }
        }

        if (XAxis == null)
        {
            XAxis = Chart.CategoryAxis;
        }

        var ticks = scale!.Ticks(YAxis?.TickDistance ?? 0);
        start = ticks.Start;
        end = ticks.End;
        step = ticks.Step;

        var categoryTicks = Chart.CategoryScale.Ticks(XAxis.TickDistance);
        x1 = Chart.CategoryScale.Scale(categoryTicks.Start);
        x2 = Chart.CategoryScale.Scale(categoryTicks.End);
        y1 = scale.Scale(start);
        y2 = scale.Scale(end);

        if (IsRightSide)
        {
            // Calculate right-side X position: after the category axis end, offset by preceding additional axes
            axisX = x2;
            foreach (var entry in Chart.AdditionalValueAxes)
            {
                if (entry.Key == AxisName) break;
                axisX += entry.Value.Measure(Chart, Chart.GetValueScale(entry.Key));
            }
        }
        else
        {
            axisX = x1;
        }
    }
}
