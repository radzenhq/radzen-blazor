@using Radzen.Blazor
@using Radzen.Documents.Spreadsheet
@inject DialogService DialogService
@inject Localizer Localizer

<RadzenStack Gap="1rem" Style="min-width:320px">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenLabel Text=@L(nameof(RadzenStrings.Spreadsheet_Top10Show)) />
        <RadzenDropDown TValue="bool" Data=@DirectionOptions
            TextProperty="Text" ValueProperty="Value"
            @bind-Value=@bottom Style="width:90px" />
        <RadzenNumeric TValue="int" @bind-Value=@count Min="1" Max="100" Style="width:80px" />
        <RadzenDropDown TValue="bool" Data=@UnitOptions
            TextProperty="Text" ValueProperty="Value"
            @bind-Value=@percent Style="width:110px" />
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
        <RadzenButton Text=@L(nameof(RadzenStrings.Spreadsheet_OK)) ButtonStyle="ButtonStyle.Primary"
            Size="ButtonSize.Small" Click=@OnOk />
        <RadzenButton Text=@L(nameof(RadzenStrings.Spreadsheet_Cancel)) ButtonStyle="ButtonStyle.Base"
            Size="ButtonSize.Small" Click=@OnCancel />
    </RadzenStack>
</RadzenStack>

@code {
#nullable enable

    /// <summary>Result returned by the dialog.</summary>
    public sealed record Result(int Count, bool Percent, bool Bottom);

    private string L(string key) => Localizer.Get(key, System.Globalization.CultureInfo.CurrentUICulture);

    private bool bottom;          // false = top, true = bottom
    private bool percent;         // false = items, true = percent
    private int count = 10;

    private object[] DirectionOptions =>
    [
        new { Text = L(nameof(RadzenStrings.Spreadsheet_Top10DirectionTop)), Value = false },
        new { Text = L(nameof(RadzenStrings.Spreadsheet_Top10DirectionBottom)), Value = true },
    ];

    private object[] UnitOptions =>
    [
        new { Text = L(nameof(RadzenStrings.Spreadsheet_Top10UnitItems)), Value = false },
        new { Text = L(nameof(RadzenStrings.Spreadsheet_Top10UnitPercent)), Value = true },
    ];

    private void OnOk() => DialogService.Close(new Result(count, percent, bottom));
    private void OnCancel() => DialogService.Close(null);
}
