@using Microsoft.AspNetCore.Components
@using Radzen.Blazor.Spreadsheet

<RadzenStack Orientation="Orientation.Horizontal" Gap="16px" Style="min-height: 320px">
    <RadzenListBox @bind-Value=@selectedCategory Data=@categories TValue="NumberFormatCategory"
        Style="width: 140px; height: 320px" Change=@OnCategoryChanged />

    <RadzenStack Orientation="Orientation.Vertical" Gap="12px" Style="flex: 1">
        <RadzenStack Orientation="Orientation.Vertical" Gap="4px">
            <RadzenLabel Text="Sample" />
            <RadzenTextBox Value=@preview ReadOnly="true" Style="font-weight: bold" />
        </RadzenStack>

        @if (ShowDecimalPlaces)
        {
            <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" AlignItems="AlignItems.Center">
                <RadzenLabel Text="Decimal places:" />
                <RadzenNumeric @bind-Value=@decimalPlaces Min="0" Max="30" Style="width: 80px"
                    Change=@OnOptionChanged TValue="int" />
            </RadzenStack>
        }

        @if (ShowThousandsSeparator)
        {
            <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" AlignItems="AlignItems.Center">
                <RadzenCheckBox @bind-Value=@useThousandsSeparator TValue="bool"
                    Change=@OnOptionChanged />
                <RadzenLabel Text="Use 1000 separator" />
            </RadzenStack>
        }

        @if (ShowCurrencySymbol)
        {
            <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" AlignItems="AlignItems.Center">
                <RadzenLabel Text="Symbol:" />
                <RadzenDropDown @bind-Value=@currencySymbol Data=@FormatCodeBuilder.CurrencySymbols
                    Style="width: 80px" Change=@OnOptionChanged TValue="string" />
            </RadzenStack>
        }

        @if (ShowPresetList)
        {
            <RadzenStack Orientation="Orientation.Vertical" Gap="4px">
                <RadzenLabel Text="Type:" />
                <RadzenListBox @bind-Value=@selectedPreset Data=@presets TextProperty="Item1" ValueProperty="Item2"
                    Style="height: 160px" TValue="string" Change=@OnPresetChanged />
            </RadzenStack>
        }

        <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" AlignItems="AlignItems.Center">
            <RadzenLabel Text="Format code:" />
            <RadzenTextBox @bind-Value=@customFormatCode Style="flex: 1" Change=@OnFormatCodeChanged />
        </RadzenStack>
    </RadzenStack>
</RadzenStack>

<RadzenStack Orientation="Orientation.Horizontal" Gap="10px" JustifyContent="JustifyContent.End" Style="margin-top: 16px">
    <RadzenButton Text="OK" Click=@OnOk ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" />
    <RadzenButton Text="Cancel" Click=@OnCancel ButtonStyle="ButtonStyle.Base" Size="ButtonSize.Small" />
</RadzenStack>
