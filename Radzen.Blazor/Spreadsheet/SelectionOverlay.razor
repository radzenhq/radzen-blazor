@using Radzen.Documents.Spreadsheet
@if (Worksheet.Selection.Cell != CellRef.Invalid)
{
    <CellSelection Context=@Context Cell=@Worksheet.Selection.Cell Worksheet=@Worksheet />
}
@foreach (var range in Context.GetRanges(Worksheet.Selection.Range))
{
    <RangeSelectionItem Context=@Context Range=@range.Range Worksheet=@Worksheet Cell=@Worksheet.Selection.Cell FrozenRow=@range.FrozenRow 
                        FrozenColumn=@range.FrozenColumn Top=@range.Top Left=@range.Left Bottom=@range.Bottom Right=@range.Right />
}