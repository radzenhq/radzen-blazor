@using Radzen.Blazor.Spreadsheet
@using Radzen.Documents.Spreadsheet
@inherits SpreadsheetToolBase
@inject DialogService DialogService

<RadzenButton ButtonStyle="ButtonStyle.Base" Size="ButtonSize.Small" ButtonType="ButtonType.Button"
    Disabled=@IsDisabled
    Click=@OnClick
    Icon="sort"
    title=@(Spreadsheet?.Localize("Spreadsheet_CustomSort") ?? "Custom Sort...") />

@code {
#nullable enable

    private async Task OnClick()
    {
        if (Worksheet is null || Worksheet.Selection.Cell == CellRef.Invalid) return;

        var range = ResolveSortRange();
        if (range == RangeRef.Invalid) return;

        // Try to harvest header names from the first row of the range.
        var columnNames = new System.Collections.Generic.List<string>();
        for (var c = range.Start.Column; c <= range.End.Column; c++)
        {
            var headerCell = Worksheet.Cells[range.Start.Row, c];
            columnNames.Add(headerCell.Value?.ToString() ?? "");
        }

        var args = new System.Collections.Generic.Dictionary<string, object?>
        {
            ["Range"] = range,
            ["ColumnNames"] = columnNames,
        };

        var result = await DialogService.OpenAsync<CustomSortDialog>(
            Spreadsheet?.Localize("Spreadsheet_CustomSort") ?? "Custom Sort",
            args,
            new DialogOptions { Width = "640px", ShowClose = true });

        if (result is CustomSortDialog.Result r && r.Keys.Length > 0)
        {
            var command = new MultiKeySortCommand(Worksheet, range, r.Keys, skipHeaderRow: r.HasHeaders);
            Spreadsheet?.Execute(command);
        }
    }

    private RangeRef ResolveSortRange()
    {
        var sel = Worksheet!.Selection.Range;
        // Single-cell selection: expand to the contiguous data region around it.
        if (sel.Start == sel.End)
        {
            // Match Excel's "Sort..." behavior — sort the active sheet's used range or the
            // selection's single column extended down. For v1 we use the full sheet bounds.
            return new RangeRef(
                new CellRef(0, 0),
                new CellRef(Worksheet.RowCount - 1, Worksheet.ColumnCount - 1));
        }
        return sel;
    }
}
