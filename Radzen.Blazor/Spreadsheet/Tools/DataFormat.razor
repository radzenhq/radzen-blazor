@using Radzen.Blazor
@using Radzen.Blazor.Spreadsheet
@using Radzen.Documents.Spreadsheet
@implements IDisposable

<RadzenDropDown @bind-Value=@CurrentFormat Data=@FormatOptions TextProperty="Name" ValueProperty="FormatCode"
    Disabled=@IsDisabled InputSize="InputSize.Small" Style="width: 130px" />

@code {
#nullable enable

    [Parameter]
    public Worksheet? Worksheet { get; set; }

    [CascadingParameter]
    public ISpreadsheet? Spreadsheet { get; set; }

    private List<FormatOption>? formatOptions;
    private List<FormatOption> FormatOptions => formatOptions ??=
    [
        new(Spreadsheet?.Localize(nameof(RadzenStrings.Spreadsheet_FormatGeneral)) ?? "General", "General"),
        new(Spreadsheet?.Localize(nameof(RadzenStrings.Spreadsheet_FormatNumber)) ?? "Number", "#,##0.00"),
        new(Spreadsheet?.Localize(nameof(RadzenStrings.Spreadsheet_FormatCurrency)) ?? "Currency", "$#,##0.00"),
        new(Spreadsheet?.Localize(nameof(RadzenStrings.Spreadsheet_FormatAccounting)) ?? "Accounting", "_($* #,##0.00_);_($* (#,##0.00);_($* \"-\"??_);_(@_)"),
        new(Spreadsheet?.Localize(nameof(RadzenStrings.Spreadsheet_FormatPercentage)) ?? "Percentage", "0%"),
        new(Spreadsheet?.Localize(nameof(RadzenStrings.Spreadsheet_FormatScientific)) ?? "Scientific", "0.00E+00"),
        new(Spreadsheet?.Localize(nameof(RadzenStrings.Spreadsheet_FormatDate)) ?? "Date", "mm/dd/yyyy"),
        new(Spreadsheet?.Localize(nameof(RadzenStrings.Spreadsheet_FormatTime)) ?? "Time", "h:mm AM/PM"),
        new(Spreadsheet?.Localize(nameof(RadzenStrings.Spreadsheet_FormatText)) ?? "Text", "@")
    ];

    private string CurrentFormat
    {
        get
        {
            if (Worksheet?.Cells.TryGet(Worksheet.Selection.Cell.Row, Worksheet.Selection.Cell.Column, out var cell) == true)
            {
                return cell.Format.NumberFormat ?? "General";
            }
            return "General";
        }
        set
        {
            if (Worksheet is not null && Worksheet.Selection.Cell != CellRef.Invalid)
            {
                if (Worksheet.Cells.TryGet(Worksheet.Selection.Cell.Row, Worksheet.Selection.Cell.Column, out var cell))
                {
                    var format = value == "General" ? null : value;
                    var command = new FormatCommand(Worksheet, Worksheet.Selection.Range, cell.Format.WithNumberFormat(format));
                    Spreadsheet?.Execute(command);
                }
            }
        }
    }

    private bool IsDisabled => Worksheet?.Selection.Cell == CellRef.Invalid;

    public override async Task SetParametersAsync(ParameterView parameters)
    {
        if (Worksheet?.Selection is not null)
        {
            Worksheet.Selection.Changed -= OnSelectionChanged;
        }

        await base.SetParametersAsync(parameters);

        if (Worksheet?.Selection is not null)
        {
            Worksheet.Selection.Changed += OnSelectionChanged;
        }
    }

    private void OnSelectionChanged()
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        if (Worksheet?.Selection is not null)
        {
            Worksheet.Selection.Changed -= OnSelectionChanged;
        }
    }

    private sealed class FormatOption(string name, string formatCode)
    {
        public string Name { get; } = name;
        public string FormatCode { get; } = formatCode;
    }
}
