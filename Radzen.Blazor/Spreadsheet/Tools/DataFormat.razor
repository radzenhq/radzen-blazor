@using Radzen.Blazor.Spreadsheet
@implements IDisposable

<RadzenDropDown @bind-Value=@CurrentFormat Data=@FormatOptions TextProperty="Name" ValueProperty="FormatCode"
    Disabled=@IsDisabled Style="width: 130px" />

@code {
#nullable enable

    [Parameter]
    public Sheet? Sheet { get; set; }

    private static readonly List<FormatOption> FormatOptions =
    [
        new("General", "General"),
        new("Number", "#,##0.00"),
        new("Currency", "$#,##0.00"),
        new("Percentage", "0%"),
        new("Date", "mm/dd/yyyy"),
        new("Time", "h:mm AM/PM"),
        new("Text", "@")
    ];

    private string CurrentFormat
    {
        get
        {
            if (Sheet?.Cells.TryGet(Sheet.Selection.Cell.Row, Sheet.Selection.Cell.Column, out var cell) == true)
            {
                return cell.Format.NumberFormat ?? "General";
            }
            return "General";
        }
        set
        {
            if (Sheet != null && Sheet.Selection.Cell != CellRef.Invalid)
            {
                if (Sheet.Cells.TryGet(Sheet.Selection.Cell.Row, Sheet.Selection.Cell.Column, out var cell))
                {
                    var format = value == "General" ? null : value;
                    var command = new FormatCommand(Sheet, Sheet.Selection.Range, cell.Format.WithNumberFormat(format));
                    Sheet.Commands.Execute(command);
                }
            }
        }
    }

    private bool IsDisabled => Sheet?.Selection.Cell == CellRef.Invalid;

    public override async Task SetParametersAsync(ParameterView parameters)
    {
        if (Sheet?.Selection != null)
        {
            Sheet.Selection.Changed -= OnSelectionChanged;
        }

        await base.SetParametersAsync(parameters);

        if (Sheet?.Selection != null)
        {
            Sheet.Selection.Changed += OnSelectionChanged;
        }
    }

    private void OnSelectionChanged()
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        if (Sheet?.Selection != null)
        {
            Sheet.Selection.Changed -= OnSelectionChanged;
        }
    }

    private sealed class FormatOption(string name, string formatCode)
    {
        public string Name { get; } = name;
        public string FormatCode { get; } = formatCode;
    }
}
