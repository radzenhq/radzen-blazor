@using Radzen.Documents.Spreadsheet
@inherits FormatToggleToolBase

<RadzenToggleButton @bind-Value=@IsToggled Icon="strikethrough_s" Disabled=@IsDisabled ButtonStyle="ButtonStyle.Base" />

@code {
    protected override bool GetValue(Format format) => format.Strikethrough;
    protected override Format WithValue(Format format, bool value) => format.WithStrikethrough(value);
}
