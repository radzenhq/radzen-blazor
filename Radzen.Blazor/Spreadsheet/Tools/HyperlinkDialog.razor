@using Radzen.Blazor.Spreadsheet

<RadzenStack Gap="1rem" Style="padding: 1rem">
    <RadzenFormField Text="URL">
        <RadzenTextBox @bind-Value=@Url Style="width: 100%" />
    </RadzenFormField>
    <RadzenFormField Text="Display Text">
        <RadzenTextBox @bind-Value=@DisplayText Style="width: 100%" />
    </RadzenFormField>
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="OK" Click=@OnOk ButtonStyle="ButtonStyle.Primary" />
        <RadzenButton Text="Cancel" Click=@OnCancel ButtonStyle="ButtonStyle.Light" />
    </RadzenStack>
</RadzenStack>

@code {
#nullable enable

    [Parameter]
    public string Url { get; set; } = "";

    [Parameter]
    public string DisplayText { get; set; } = "";

    [Inject]
    public DialogService DialogService { get; set; } = default!;

    private void OnOk()
    {
        if (!string.IsNullOrWhiteSpace(Url))
        {
            DialogService.Close(new Hyperlink
            {
                Url = Url,
                DisplayText = string.IsNullOrWhiteSpace(DisplayText) ? null : DisplayText
            });
        }
    }

    private void OnCancel()
    {
        DialogService.Close(null);
    }
}
