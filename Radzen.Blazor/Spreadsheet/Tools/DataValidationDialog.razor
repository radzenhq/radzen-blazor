@using Radzen.Blazor.Spreadsheet
@using Radzen.Documents.Spreadsheet

<RadzenStack Gap="1rem" Style="padding: 1rem; min-width: 400px">
    <RadzenFormField Text="Validation Type">
        <RadzenDropDown @bind-Value=@ValidationType Data=@ValidationTypes TextProperty="Name" ValueProperty="Value" Style="width: 100%" Change=@OnTypeChanged />
    </RadzenFormField>

    @if (ValidationType != DataValidationType.List && ValidationType != DataValidationType.Custom)
    {
        <RadzenFormField Text="Operator">
            <RadzenDropDown @bind-Value=@Operator Data=@Operators TextProperty="Name" ValueProperty="Value" Style="width: 100%" />
        </RadzenFormField>
    }

    @if (ValidationType == DataValidationType.Custom)
    {
        <RadzenFormField Text="Formula">
            <RadzenTextBox @bind-Value=@Formula1 Style="width: 100%" />
        </RadzenFormField>
    }
    else if (ValidationType == DataValidationType.List)
    {
        <RadzenFormField Text="Values (comma separated)">
            <RadzenTextArea @bind-Value=@Formula1 Rows="3" Style="width: 100%" />
        </RadzenFormField>
    }
    else if (Operator == DataValidationOperator.Between || Operator == DataValidationOperator.NotBetween)
    {
        @if (ValidationType == DataValidationType.Date)
        {
            <RadzenFormField Text="Minimum">
                <RadzenDatePicker @bind-Value=@Formula1Date DateFormat="yyyy-MM-dd" Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="Maximum">
                <RadzenDatePicker @bind-Value=@Formula2Date DateFormat="yyyy-MM-dd" Style="width: 100%" />
            </RadzenFormField>
        }
        else if (ValidationType == DataValidationType.Time)
        {
            <RadzenFormField Text="Minimum">
                <RadzenDatePicker @bind-Value=@Formula1Date ShowTime="true" TimeOnly="true" Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="Maximum">
                <RadzenDatePicker @bind-Value=@Formula2Date ShowTime="true" TimeOnly="true" Style="width: 100%" />
            </RadzenFormField>
        }
        else
        {
            <RadzenFormField Text="Minimum">
                <RadzenTextBox @bind-Value=@Formula1 Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="Maximum">
                <RadzenTextBox @bind-Value=@Formula2 Style="width: 100%" />
            </RadzenFormField>
        }
    }
    else
    {
        @if (ValidationType == DataValidationType.Date)
        {
            <RadzenFormField Text="Value">
                <RadzenDatePicker @bind-Value=@Formula1Date DateFormat="yyyy-MM-dd" Style="width: 100%" />
            </RadzenFormField>
        }
        else if (ValidationType == DataValidationType.Time)
        {
            <RadzenFormField Text="Value">
                <RadzenDatePicker @bind-Value=@Formula1Date ShowTime="true" TimeOnly="true" Style="width: 100%" />
            </RadzenFormField>
        }
        else
        {
            <RadzenFormField Text="Value">
                <RadzenTextBox @bind-Value=@Formula1 Style="width: 100%" />
            </RadzenFormField>
        }
    }

    <RadzenCheckBox @bind-Value=@AllowBlank TValue="bool" />
    <RadzenLabel Text="Allow blank" Component="AllowBlank" Style="margin-left: 0.5rem" />

    <RadzenFieldset Text="Error Alert">
        <RadzenStack Gap="0.5rem">
            <RadzenFormField Text="Style">
                <RadzenDropDown @bind-Value=@ErrorStyle Data=@ErrorStyles TextProperty="Name" ValueProperty="Value" Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="Title">
                <RadzenTextBox @bind-Value=@ErrorTitle Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="Message">
                <RadzenTextArea @bind-Value=@ErrorMessage Rows="2" Style="width: 100%" />
            </RadzenFormField>
        </RadzenStack>
    </RadzenFieldset>

    <RadzenFieldset Text="Input Prompt">
        <RadzenStack Gap="0.5rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                <RadzenCheckBox @bind-Value=@ShowInputMessage TValue="bool" />
                <RadzenLabel Text="Show input message when cell is selected" />
            </RadzenStack>
            <RadzenFormField Text="Title">
                <RadzenTextBox @bind-Value=@PromptTitle Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="Message">
                <RadzenTextArea @bind-Value=@PromptMessage Rows="2" Style="width: 100%" />
            </RadzenFormField>
        </RadzenStack>
    </RadzenFieldset>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="OK" Click=@OnOk ButtonStyle="ButtonStyle.Primary" />
        <RadzenButton Text="Cancel" Click=@OnCancel ButtonStyle="ButtonStyle.Light" />
    </RadzenStack>
</RadzenStack>

@code {
#nullable enable
    [Inject]
    public DialogService DialogService { get; set; } = default!;

    private DataValidationType ValidationType { get; set; } = DataValidationType.WholeNumber;
    private DataValidationOperator Operator { get; set; } = DataValidationOperator.Between;
    private string Formula1 { get; set; } = "";
    private string Formula2 { get; set; } = "";
    private bool AllowBlank { get; set; } = true;
    private DataValidationErrorStyle ErrorStyle { get; set; } = DataValidationErrorStyle.Stop;
    private string ErrorTitle { get; set; } = "";
    private string ErrorMessage { get; set; } = "The value you entered is not valid.";
    private bool ShowInputMessage { get; set; }
    private string PromptTitle { get; set; } = "";
    private string PromptMessage { get; set; } = "";
    private DateTime? Formula1Date { get; set; }
    private DateTime? Formula2Date { get; set; }

    private static readonly List<DropDownItem<DataValidationType>> ValidationTypes =
    [
        new("Whole Number", DataValidationType.WholeNumber),
        new("Decimal", DataValidationType.Decimal),
        new("List", DataValidationType.List),
        new("Date", DataValidationType.Date),
        new("Time", DataValidationType.Time),
        new("Text Length", DataValidationType.TextLength),
        new("Custom", DataValidationType.Custom)
    ];

    private static readonly List<DropDownItem<DataValidationOperator>> AllOperators =
    [
        new("Between", DataValidationOperator.Between),
        new("Not Between", DataValidationOperator.NotBetween),
        new("Equal To", DataValidationOperator.Equal),
        new("Not Equal To", DataValidationOperator.NotEqual),
        new("Greater Than", DataValidationOperator.GreaterThan),
        new("Less Than", DataValidationOperator.LessThan),
        new("Greater Than or Equal", DataValidationOperator.GreaterThanOrEqual),
        new("Less Than or Equal", DataValidationOperator.LessThanOrEqual)
    ];

    private static readonly List<DropDownItem<DataValidationErrorStyle>> ErrorStyles =
    [
        new("Stop", DataValidationErrorStyle.Stop),
        new("Warning", DataValidationErrorStyle.Warning),
        new("Information", DataValidationErrorStyle.Information)
    ];

    private List<DropDownItem<DataValidationOperator>> Operators => AllOperators;

    private void OnTypeChanged()
    {
        if (ValidationType == DataValidationType.List)
        {
            Operator = DataValidationOperator.Equal;
        }
    }

    private void OnOk()
    {
        var formula1 = Formula1;
        var formula2 = Formula2;

        if (ValidationType == DataValidationType.Date)
        {
            if (Formula1Date.HasValue)
            {
                formula1 = Formula1Date.Value.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture);
            }
            if (Formula2Date.HasValue)
            {
                formula2 = Formula2Date.Value.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture);
            }
        }
        else if (ValidationType == DataValidationType.Time)
        {
            if (Formula1Date.HasValue)
            {
                formula1 = (Formula1Date.Value.TimeOfDay.TotalDays).ToString(System.Globalization.CultureInfo.InvariantCulture);
            }
            if (Formula2Date.HasValue)
            {
                formula2 = (Formula2Date.Value.TimeOfDay.TotalDays).ToString(System.Globalization.CultureInfo.InvariantCulture);
            }
        }

        var rule = new DataValidationRule
        {
            Type = ValidationType,
            Operator = Operator,
            Formula1 = formula1,
            Formula2 = formula2,
            AllowBlank = AllowBlank,
            ErrorStyle = ErrorStyle,
            ErrorTitle = string.IsNullOrEmpty(ErrorTitle) ? null : ErrorTitle,
            Error = string.IsNullOrEmpty(ErrorMessage) ? "The value you entered is not valid." : ErrorMessage,
            ShowErrorMessage = true,
            ShowInputMessage = ShowInputMessage,
            PromptTitle = string.IsNullOrEmpty(PromptTitle) ? null : PromptTitle,
            Prompt = string.IsNullOrEmpty(PromptMessage) ? null : PromptMessage
        };

        DialogService.Close(rule);
    }

    private void OnCancel()
    {
        DialogService.Close(null);
    }

    private sealed class DropDownItem<T>(string name, T value)
    {
        public string Name { get; } = name;
        public T Value { get; } = value;
    }
}
