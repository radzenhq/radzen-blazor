@using Radzen.Blazor.Spreadsheet
@using Radzen.Documents.Spreadsheet

<RadzenStack Gap="1rem" Style="padding: 1rem; min-width: 350px">
    <RadzenFormField Text="Rule Type">
        <RadzenDropDown @bind-Value=@RuleType Data=@RuleTypes TextProperty="Name" ValueProperty="Value" Style="width: 100%" />
    </RadzenFormField>

    @if (RuleType == ConditionalFormatRuleType.GreaterThan || RuleType == ConditionalFormatRuleType.LessThan || RuleType == ConditionalFormatRuleType.EqualTo)
    {
        <RadzenFormField Text="Value">
            <RadzenTextBox @bind-Value=@Value1 Style="width: 100%" />
        </RadzenFormField>
    }

    @if (RuleType == ConditionalFormatRuleType.Between)
    {
        <RadzenFormField Text="Minimum">
            <RadzenTextBox @bind-Value=@Value1 Style="width: 100%" />
        </RadzenFormField>
        <RadzenFormField Text="Maximum">
            <RadzenTextBox @bind-Value=@Value2 Style="width: 100%" />
        </RadzenFormField>
    }

    @if (RuleType == ConditionalFormatRuleType.TextContains)
    {
        <RadzenFormField Text="Text">
            <RadzenTextBox @bind-Value=@Value1 Style="width: 100%" />
        </RadzenFormField>
    }

    <RadzenFormField Text="Background Color">
        <RadzenColorPicker @bind-Value=@BackgroundColor Style="width: 100%" />
    </RadzenFormField>

    <RadzenFormField Text="Text Color">
        <RadzenColorPicker @bind-Value=@TextColor Style="width: 100%" />
    </RadzenFormField>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="OK" Click=@OnOk ButtonStyle="ButtonStyle.Primary" />
        <RadzenButton Text="Cancel" Click=@OnCancel ButtonStyle="ButtonStyle.Light" />
    </RadzenStack>
</RadzenStack>

@code {
#nullable enable
    [Inject]
    public DialogService DialogService { get; set; } = default!;

    [Parameter]
    public ConditionalFormatRuleType RuleType { get; set; } = ConditionalFormatRuleType.GreaterThan;

    private string Value1 { get; set; } = "";
    private string Value2 { get; set; } = "";
    private string BackgroundColor { get; set; } = "#FFEB9C";
    private string TextColor { get; set; } = "#9C5700";

    private static readonly List<DropDownItem<ConditionalFormatRuleType>> RuleTypes =
    [
        new("Greater Than", ConditionalFormatRuleType.GreaterThan),
        new("Less Than", ConditionalFormatRuleType.LessThan),
        new("Between", ConditionalFormatRuleType.Between),
        new("Equal To", ConditionalFormatRuleType.EqualTo),
        new("Text Contains", ConditionalFormatRuleType.TextContains)
    ];

    private void OnOk()
    {
        var format = new Format { BackgroundColor = BackgroundColor, Color = TextColor };
        ConditionalFormatBase? rule = RuleType switch
        {
            ConditionalFormatRuleType.GreaterThan when double.TryParse(Value1, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var v) =>
                new GreaterThanRule { Value = v, Format = format },
            ConditionalFormatRuleType.LessThan when double.TryParse(Value1, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var v) =>
                new LessThanRule { Value = v, Format = format },
            ConditionalFormatRuleType.Between when double.TryParse(Value1, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var min) &&
                double.TryParse(Value2, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var max) =>
                new BetweenRule { Minimum = min, Maximum = max, Format = format },
            ConditionalFormatRuleType.EqualTo => new EqualToRule { Value = Value1, Format = format },
            ConditionalFormatRuleType.TextContains => new TextContainsRule { Text = Value1, Format = format },
            _ => null
        };

        if (rule is not null)
        {
            DialogService.Close(rule);
        }
    }

    private void OnCancel()
    {
        DialogService.Close(null);
    }

    private sealed class DropDownItem<T>(string name, T value)
    {
        public string Name { get; } = name;
        public T Value { get; } = value;
    }
}
