@using Radzen.Blazor.Spreadsheet
@using Radzen.Documents.Spreadsheet
<RadzenButton ButtonStyle="ButtonStyle.Base" Click=@OnDeleteRowClick Icon="delete" ButtonType="ButtonType.Button" Disabled=@IsDisabled />
@code {
#nullable enable

    [Parameter]
    public Worksheet? Worksheet { get; set; }

    private bool IsDisabled => Worksheet == null || Worksheet.Selection.Cell == CellRef.Invalid;

    private void OnDeleteRowClick()
    {
        if (Worksheet == null)
        {
            return;
        }

        var range = Worksheet.Selection.Range;
        var start = range.Start.Row;
        var end = range.End.Row;
        Worksheet.Commands.Execute(new DeleteRowsCommand(Worksheet, start, end));
    }
}