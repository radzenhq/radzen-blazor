@using Radzen.Blazor.Spreadsheet
@using Radzen.Documents.Spreadsheet

<RadzenSplitButton Click=@OnClick Icon="merge_type" Disabled=@IsDisabled ButtonStyle="ButtonStyle.Base" Size="ButtonSize.Small">
    <ChildContent>
        <RadzenSplitButtonItem Text="Merge && Center" Value="merge-center" />
        <RadzenSplitButtonItem Text="Merge Cells" Value="merge" />
        <RadzenSplitButtonItem Text="Unmerge Cells" Value="unmerge" />
    </ChildContent>
</RadzenSplitButton>

@code {
#nullable enable

    [Parameter]
    public Worksheet? Worksheet { get; set; }

    private bool IsDisabled => Worksheet?.Selection.Cell == CellRef.Invalid;

    private void OnClick(RadzenSplitButtonItem? item)
    {
        if (Worksheet == null || Worksheet.Selection.Cell == CellRef.Invalid)
        {
            return;
        }

        var value = item?.Value;

        switch (value)
        {
            case "merge-center":
            case null:
            {
                var command = new MergeCellsCommand(Worksheet, Worksheet.Selection.Range, center: true);
                Worksheet.Commands.Execute(command);
                break;
            }
            case "merge":
            {
                var command = new MergeCellsCommand(Worksheet, Worksheet.Selection.Range);
                Worksheet.Commands.Execute(command);
                break;
            }
            case "unmerge":
            {
                var command = new UnmergeCellsCommand(Worksheet, Worksheet.Selection.Cell);
                Worksheet.Commands.Execute(command);
                break;
            }
        }
    }
}
