@using Radzen
@using Radzen.Blazor.Spreadsheet
@using Radzen.Documents.Spreadsheet
<RadzenButton ButtonStyle="ButtonStyle.Base" Click=@OnInsertColumnBeforeClick Icon="add_column_left" ButtonType="ButtonType.Button" Disabled=@IsDisabled />
@code {
#nullable enable

    [Parameter]
    public Worksheet? Worksheet { get; set; }

    private bool IsDisabled => Worksheet == null || Worksheet.Selection.Cell == CellRef.Invalid;

    private void OnInsertColumnBeforeClick()
    {
        if (Worksheet == null)
        {
            return;
        }
        Worksheet.Commands.Execute(new InsertColumnBeforeCommand(Worksheet, Worksheet.Selection.Range.Start.Column));
    }
}


