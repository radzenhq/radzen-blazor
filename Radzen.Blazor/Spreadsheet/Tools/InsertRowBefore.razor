@using Radzen
@using Radzen.Blazor.Spreadsheet
@using Radzen.Documents.Spreadsheet
<RadzenButton ButtonStyle="ButtonStyle.Base" Click=@OnInsertRowBeforeClick Icon="add_row_above" ButtonType="ButtonType.Button" Disabled=@IsDisabled />
@code {
#nullable enable

    [Parameter]
    public Worksheet? Worksheet { get; set; }

    [CascadingParameter]
    public ISpreadsheet? Spreadsheet { get; set; }

    private bool IsDisabled => Worksheet == null || Worksheet.Selection.Cell == CellRef.Invalid;

    private void OnInsertRowBeforeClick()
    {
        if (Worksheet == null)
        {
            return;
        }

        Spreadsheet?.Execute(new InsertRowBeforeCommand(Worksheet, Worksheet.Selection.Range.Start.Row));
    }
}