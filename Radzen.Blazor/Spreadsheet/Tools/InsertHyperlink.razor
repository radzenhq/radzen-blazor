@using Radzen.Blazor
@using Radzen.Blazor.Spreadsheet
@using Radzen.Documents.Spreadsheet
@inherits SpreadsheetToolBase
@inject DialogService DialogService

<RadzenButton Icon="link" Disabled=@IsDisabled ButtonStyle="ButtonStyle.Base" Click=@OnClickAsync Size="ButtonSize.Small"
    title=@(Spreadsheet?.Localize(nameof(RadzenStrings.Spreadsheet_InsertHyperlink)) ?? "Insert Hyperlink") />

@code {
    private async Task OnClickAsync()
    {
        if (Worksheet is null || Worksheet.Selection.Cell == CellRef.Invalid)
        {
            return;
        }

        var address = Worksheet.Selection.Cell;
        Worksheet.Cells.TryGet(address.Row, address.Column, out var cell);

        var existing = cell?.Hyperlink;
        var url = existing?.Url ?? "";
        var displayText = existing?.Text ?? cell?.Value?.ToString() ?? "";

        var result = await DialogService.OpenAsync<HyperlinkDialog>(Spreadsheet?.Localize(nameof(RadzenStrings.Spreadsheet_InsertHyperlinkTitle)) ?? "Insert Hyperlink",
            new Dictionary<string, object?>
            {
                { "Url", url },
                { "Text", displayText }
            });

        if (result is Hyperlink hyperlink)
        {
            var command = new HyperlinkCommand(Worksheet, address, hyperlink);
            Spreadsheet?.Execute(command);
        }
    }
}
