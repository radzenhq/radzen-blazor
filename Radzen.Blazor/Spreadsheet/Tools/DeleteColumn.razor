@using Radzen
@using Radzen.Blazor.Spreadsheet
@using Radzen.Documents.Spreadsheet
<RadzenButton ButtonStyle="ButtonStyle.Base" Click=@OnDeleteColumnClick Icon="delete" ButtonType="ButtonType.Button" Disabled=@IsDisabled />
@code {
#nullable enable

    [Parameter]
    public Worksheet? Worksheet { get; set; }

    [CascadingParameter]
    public ISpreadsheet? Spreadsheet { get; set; }

    private bool IsDisabled => Worksheet is null || Worksheet.Selection.Cell == CellRef.Invalid;

    private void OnDeleteColumnClick()
    {
        if (Worksheet is null)
        {
            return;
        }
        var range = Worksheet.Selection.Range;
        var start = range.Start.Column;
        var end = range.End.Column;
        Spreadsheet?.Execute(new DeleteColumnsCommand(Worksheet, start, end));
    }
}


