@using Microsoft.AspNetCore.Components
@using Radzen.Blazor

<RadzenStack Orientation="Orientation.Vertical" Gap="16px">
    <RadzenTextBox @bind-Value=@Name Style="width: 100%" />
    @if (!string.IsNullOrEmpty(error))
    {
        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-form-error-color, #f44336)">@error</RadzenText>
    }
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
        <RadzenButton Text=@L(nameof(RadzenStrings.Spreadsheet_Cancel)) Click=@OnCancel ButtonStyle="ButtonStyle.Base" Variant="Variant.Outlined" />
        <RadzenButton Text=@L(nameof(RadzenStrings.Spreadsheet_OK)) Click=@OnOk ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" />
    </RadzenStack>
</RadzenStack>