@using Radzen.Blazor
@using Radzen.Blazor.Rendering

@inherits SchedulerViewBase

@code {
    public override RenderFragment Render()
    {
        var appointments = Scheduler?.GetAppointmentsInRange(StartDate, EndDate).ToList() ?? new List<AppointmentData>();

        if (HasResourceGroups)
        {
            return
    @<CascadingValue Value=@Scheduler>
        <ResourceGroups Types=@ResourceTypes Orientation=@GroupOrientation>
            <ChildContent Context="path">
                <AgendaView StartDate=@StartDate EndDate=@EndDate Appointments=@AppointmentsForResources(appointments, path) Resources=@path TimeFormat=@TimeFormat MultiDayText=@MultiDayText AppointmentMove=OnAppointmentMove />
            </ChildContent>
        </ResourceGroups>
    </CascadingValue>
    ;
        }

        return
    @<CascadingValue Value=@Scheduler>
        <AgendaView StartDate=@StartDate EndDate=@EndDate Appointments=@appointments TimeFormat=@TimeFormat MultiDayText=@MultiDayText AppointmentMove=OnAppointmentMove />
    </CascadingValue>
    ;
    }
}
