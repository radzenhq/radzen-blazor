@using Radzen.Blazor
@using Radzen.Blazor.Rendering

@inherits SchedulerViewBase

@code {
    public override RenderFragment Render()
    {
        var appointments = Scheduler?.GetAppointmentsInRange(StartDate, EndDate).ToList() ?? new List<AppointmentData>();

        if (HasResourceGroups)
        {
            return @<CascadingValue Value=@Scheduler>
                <ResourceGroups Types=@ResourceTypes Orientation=@GroupOrientation>
                    <ChildContent Context="path">
                        <WeekView HeaderFormat=@HeaderFormat MinutesPerSlot=@MinutesPerSlot StartDate=@StartDate EndDate=@EndDate StartTime=@StartTime EndTime=@EndTime Appointments=@AppointmentsForResources(appointments, path) Resources=@path TimeFormat="@TimeFormat" ShowHours=@(GroupOrientation == Orientation.Vertical || IsFirstResourcePath(path)) ShowAllDay=@ShowAllDay AllDayText=@AllDayText AppointmentMove=OnAppointmentMove />
                    </ChildContent>
                </ResourceGroups>
            </CascadingValue>;
        }

        return @<CascadingValue Value=@Scheduler>
                <WeekView HeaderFormat=@HeaderFormat MinutesPerSlot=@MinutesPerSlot StartDate=@StartDate EndDate=@EndDate StartTime=@StartTime EndTime=@EndTime Appointments=@appointments TimeFormat="@TimeFormat" AppointmentMove=OnAppointmentMove />
            </CascadingValue>;
    }
}
